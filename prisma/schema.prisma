generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Core Models
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(EXPLORER)
  points    Int      @default(0)
  totalExp  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Json?

  discoveries   Discovery[]
  redemptions   Redemption[]
  achievements  UserAchievement[]
  media         Media[]
  reviews       Review[]
  notifications Notification[]
  favorites     Favorite[]
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?  // SVG or URL for Flutter
  createdAt   DateTime @default(now())
  
  places      Place[]
  routes      Route[]
}

model Difficulty {
  id          String   @id @default(uuid())
  level       String   @unique // e.g., "EASY", "MEDIUM", "HARD"
  description String?
  color       String?  // Hex code for Flutter UI
  
  routes      Route[]
}

model Place {
  id          String   @id @default(uuid())
  name        String
  description String
  latitude    Float
  longitude   Float
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  partners     Partner[]
  routePlaces  RoutePlace[]
  discoveries  Discovery[]
  media        Media[]
  reviews      Review[]
  favorites    Favorite[]
}

model Route {
  id           String   @id @default(uuid())
  name         String
  description  String?
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])
  difficultyId String
  difficulty   Difficulty @relation(fields: [difficultyId], references: [id])
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  places       RoutePlace[]
  media        Media[]
  reviews      Review[]
  favorites    Favorite[]
}

model RoutePlace {
  id      String @id @default(uuid())
  order   Int
  routeId String
  placeId String
  route   Route  @relation(fields: [routeId], references: [id])
  place   Place  @relation(fields: [placeId], references: [id])

  @@unique([routeId, placeId])
}

// Gamification Models
model Discovery {
  id        String   @id @default(uuid())
  userId    String
  placeId   String
  points    Int      @default(10) // Points earned for this discovery
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  place     Place    @relation(fields: [placeId], references: [id])
}

model Reward {
  id          String   @id @default(uuid())
  name        String
  description String?
  cost        Int      // Points needed
  stock       Int      @default(-1) // -1 for infinite
  partnerId   String
  partner     Partner  @relation(fields: [partnerId], references: [id])
  createdAt   DateTime @default(now())

  redemptions Redemption[]
}

model Redemption {
  id        String   @id @default(uuid())
  userId    String
  rewardId  String
  code      String   @unique // Generated code to claim
  claimed   Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  reward    Reward   @relation(fields: [rewardId], references: [id])
}

model Achievement {
  id          String   @id @default(uuid())
  name        String
  description String
  icon        String?
  criteria    Json?    // e.g. { "type": "visit_count", "target": 5 }

  users       UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  createdAt     DateTime @default(now())

  user          User        @relation(fields: [userId], references: [id])
  achievement   Achievement @relation(fields: [achievementId], references: [id])
}

model Partner {
  id          String   @id @default(uuid())
  name        String
  description String?
  userId      String?
  placeId     String
  place       Place    @relation(fields: [placeId], references: [id])
  rewards     Reward[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Expanded Features (Pro-Level)
model Media {
  id        String   @id @default(uuid())
  url       String   // URL del recurso
  type      MediaType @default(IMAGE)
  placeId   String?
  place     Place?   @relation(fields: [placeId], references: [id])
  routeId   String?
  route     Route?   @relation(fields: [routeId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(uuid())
  rating    Int      @default(5) // 1 a 5 estrellas
  comment   String?
  userId    String
  placeId   String?
  routeId   String?
  user      User     @relation(fields: [userId], references: [id])
  place     Place?   @relation(fields: [placeId], references: [id])
  route     Route?   @relation(fields: [routeId], references: [id])
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  read      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  placeId   String?
  routeId   String?
  user      User     @relation(fields: [userId], references: [id])
  place     Place?   @relation(fields: [placeId], references: [id])
  route     Route?   @relation(fields: [routeId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, placeId])
  @@unique([userId, routeId])
}

enum Role {
  EXPLORER
  PARTNER
  ADMIN
}

enum MediaType {
  IMAGE
  VIDEO
}

enum NotificationType {
  SYSTEM
  REWARD
  LEVEL_UP
  SOCIAL
}
